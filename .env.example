# ============================================
# Agent AI Skeleton - Environment Configuration
# ============================================

# --- App (서버 구동) ---
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# --- 추론 LLM API (에이전트의 사고 모델, OpenAI 호환) ---
LLM_API_BASE_URL=https://api.example.com/v1
LLM_API_KEY=your-llm-api-key-here
LLM_MODEL_NAME=gpt-4o
LLM_TEMPERATURE=0.0

# --- 외부 AI 모델 API (도구가 호출하는 대상) ---
MODEL_API_BASE_URL=https://api.example.com/v1
MODEL_API_KEY=your-model-api-key-here
MODEL_API_TIMEOUT_SECONDS=30
